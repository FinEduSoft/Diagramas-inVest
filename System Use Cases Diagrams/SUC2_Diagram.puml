@startuml "SUC2: Sistema Metas"
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Usuario" as User

rectangle "inVest - Sistema de Metas de Ahorro" {
    usecase "Crear Meta de Ahorro" as UC1
    usecase "Registrar Aporte a Meta" as UC2
    usecase "Visualizar Barra de Progreso" as UC3
    usecase "Otorgar Medalla por Racha" as UC4
}

UC2 <.. UC4 : <<extend>>

User --> UC1
User --> UC2
User --> UC3

@enduml