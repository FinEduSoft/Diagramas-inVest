@startuml "SUC5: Sistema Recomendaciones"
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Usuario" as User

rectangle "inVest - Sistema de Analítica y Alertas" {
    usecase "Visualizar Reporte Semanal de Salud Financiera" as UC1
    usecase "Desplegar Sugerencias Automáticas de Reporte" as UC2
}

UC1 ..> UC2 : <<include>>

User --> UC1

@enduml