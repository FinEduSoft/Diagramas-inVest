@startuml "SUC1: Sistema Flujo de Caja"
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Usuario" as User

rectangle "inVest - Sistema de Flujo de Caja" {
    usecase "Iniciar Sesión" as UC1
    usecase "Crear Billetera Independiente" as UC2
    usecase "Registrar Movimiento Manual \n (Ingreso / Gasto)" as UC3
    usecase "Clasificar Movimiento por Categoría" as UC4
    usecase "Modificar o Eliminar Transacción" as UC5
    usecase "Visualizar Balance Consolidado \n Multimoneda" as UC6
}

UC3 <.. UC4 : <<extend>> 

UC2 ..> UC1 : <<include>>
UC3 ..> UC1 : <<include>>
UC5 ..> UC1 : <<include>>
UC6 ..> UC1 : <<include>>

User --> UC2
User --> UC3
User --> UC5
User --> UC6

@enduml