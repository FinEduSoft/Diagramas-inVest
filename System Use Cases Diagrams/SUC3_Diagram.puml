@startuml "SUC3: Sistema Educación"
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Usuario" as User
actor "Administrador" as Admin

rectangle "inVest - Sistema de Educación Gamificada" {
    usecase "Gestionar Contenido de Cursos" as UC1
    usecase "Visualizar Módulos de Aprendizaje" as UC2
    usecase "Estudiar Lección Interactiva" as UC3
    usecase "Rendir Cuestionario de Evaluación Temática" as UC4
    usecase "Emitir Insignia Digital y Actualizar Racha" as UC5
    usecase "Visualizar Perfil de Logros" as UC6
}

Admin --> UC1

User --> UC2
User --> UC3
User --> UC4
User --> UC6

UC4 <-- UC5 : <<extend>>

@enduml