@startuml "SUC6: Sistema Simulador"
left to right direction

skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Usuario" as User
actor "Administrador" as Admin

rectangle "inVest - Sistema Simulador de Inversiones" {
    usecase "Actualizar Cotizaciones y Activos Disponibles" as UC1
    usecase "Visualizar Mercado de Activos" as UC2
    usecase "Filtrar Opciones por Nivel de Riesgo" as UC3
    usecase "Simular Operación de Compra / Venta" as UC4
    usecase "Monitorear Rendimiento del Portafolio Virtual" as UC5
}

UC2 <.. UC3 : <<extend>>

Admin --> UC1

User --> UC2
User --> UC4
User --> UC5

@enduml